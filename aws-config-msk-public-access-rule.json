{
  "ConfigRuleName": "msk-cluster-public-access-check",
  "Description": "Checks if Amazon MSK clusters have public access disabled. This rule is COMPLIANT if the MSK cluster does not have public access enabled, and NON_COMPLIANT if public access is enabled.",
  "Source": {
    "Owner": "CUSTOM_LAMBDA",
    "SourceIdentifier": "arn:aws:lambda:us-east-2:13437518:function:CheckMSKPublicAccess",
    "SourceDetails": [
      {
        "EventSource": "aws.config",
        "MessageType": "ConfigurationItemChangeNotification"
      },
      {
        "EventSource": "aws.config",
        "MessageType": "OversizedConfigurationItemChangeNotification"
      }
    ]
  },
  "Scope": {
    "ComplianceResourceTypes": [
      "AWS::MSK::Cluster"
    ]
  },
  "InputParameters": "{}",
  "MaximumExecutionFrequency": "TwentyFour_Hours",
  "ConfigRuleState": "ACTIVE",
  "Tags": [
    {
      "Key": "Environment",
      "Value": "Production"
    },
    {
      "Key": "Compliance",
      "Value": "Required"
    },
    {
      "Key": "Severity",
      "Value": "Critical"
    }
  ]
}
